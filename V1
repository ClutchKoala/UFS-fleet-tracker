            // Cargo Vans (12) - All hybrid references changed to ppl-cargo
            { id: 7, number: '#5', type: 'low', fuelType: 'Gas', length: null, logo: 'Plain White - Concessions', desc: 'Plain white concessions van - No logo - Gas', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null },
            { id: 8, number: '214', type: 'high', fuelType: 'Gas & Propane', length: null, logo: 'Standard', desc: 'High top - Gas & Propane', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null },
            { id: 9, number: '215', type: 'high', fuelType: 'Gas & Propane', length: null, logo: 'Standard', desc: 'High top - Gas & Propane', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null },
            { id: 10, number: '216', type: 'low', fuelType: 'Gas', length: null, logo: 'Standard', desc: 'Low roof - Gas only', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null },
            { id: 11, number: '217', type: 'low', fuelType: 'Gas', length: null, logo: 'Standard', desc: 'Low roof - Gas only', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null },
            { id: 12, number: '218', type: 'ppl-cargo', fuelType: 'Gas', seats: 5, length: null, logo: 'Standard', desc: 'PPL - Cargo van - 5 passenger capacity', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null },
            { id: 13, number: '414', type: 'refrigerated', fuelType: 'Gas', length: null, refrigerated: true, logo: 'Standard', desc: 'Refrigerated cargo van - Gas', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null },
            { id: 14, number: '415', type: 'ppl-cargo', fuelType: 'Propane & Gas', seats: 5, awd: true, length: null, logo: 'Standard', desc: 'PPL - Cargo AWD - 5 passenger - Propane & Gas', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null },
            { id: 15, number: '416', type: 'small', fuelType: 'Gas', length: null, logo: 'Standard', desc: 'Small van - Low top - Gas only', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null },
            { id: 16, number: '417', type: 'small', fuelType: 'Gas', length: null, logo: 'Floral', desc: 'Small van - Floral logo - Low top - Gas only', status: 'available', currentDriver: null, checkOutTime: null, purpose: null, fuelAtCheckOut: null, lastFuelLevel: 100, reservation: null }
        ];

        let fleetData = { vans: [], logs: [] };
        let selectedVanId = null;
        let currentFilter = 'all';
        let isAdmin = false;
        let reorderMode = false;
        let draggedItem = null;
        let longPressTimer = null;

        const vehicleTypes = {
            'people': { label: 'PEOPLE MOVER', color: 'type-people', icon: 'fa-users' },
            'box': { label: 'BOX TRUCK', color: 'type-box', icon: 'fa-truck' },
            'refrigerated': { label: 'REFRIGERATED', color: 'type-refrigerated', icon: 'fa-snowflake' },
            'low': { label: 'LOW ROOF', color: 'type-low', icon: 'fa-van-shuttle' },
            'high': { label: 'HIGH TOP', color: 'type-high', icon: 'fa-arrow-up' },
            'ppl-cargo': { label: 'PPL - CARGO', color: 'type-ppl-cargo', icon: 'fa-people-carry' },
            'small': { label: 'SMALL VAN', color: 'type-small', icon: 'fa-compress' }
        };

        function initData() {
            const savedVans = localStorage.getItem('ufs_vans');
            const savedLogs = localStorage.getItem('ufs_logs');
            const savedOrder = localStorage.getItem('ufs_van_order');
            
            if (savedVans) {
                const parsed = JSON.parse(savedVans);
                if (parsed.length === 16) {
                    fleetData.vans = parsed;
                    fleetData.vans.forEach(v => {
                        if (!v.hasOwnProperty('reservation')) v.reservation = null;
                    });
                } else {
                    fleetData.vans = JSON.parse(JSON.stringify(defaultFleet));
                    saveData();
                }
            } else {
                fleetData.vans = JSON.parse(JSON.stringify(defaultFleet));
            }
            
            if (savedOrder) {
                const order = JSON.parse(savedOrder);
                fleetData.vans.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));
            }
            
            if (savedLogs) fleetData.logs = JSON.parse(savedLogs);
            
            // REMOVED: Auto-expiration check - reservations now persist until manually cleared
        }

        document.addEventListener('DOMContentLoaded', () => {
            initData();
            updateTime();
            setInterval(updateTime, 1000);
            // REMOVED: setInterval(checkExpiredReservations, 60000) - no auto-expire
            renderFleet();
            loadLogs();
            updateStats();
            checkFuelAlerts();
        });

        function updateTime() {
            const now = new Date();
            document.getElementById('currentTime').textContent = now.toLocaleTimeString('en-US', {
                hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true
            });
        }

        function getTypeInfo(type) {
            return vehicleTypes[type] || vehicleTypes['low'];
        }

        // REMOVED: checkExpiredReservations function - no longer needed

        function isVehicleBlocked(van) {
            // Simple check - if status is blocked and has reservation, it's blocked
            // No time-based expiration
            return van.status === 'blocked' && van.reservation !== null;
        }

        function renderFleet() {
            const grid = document.getElementById('fleetGrid');
            grid.innerHTML = '';
            
            const filtered = fleetData.vans.filter(van => {
                if (currentFilter === 'all') return true;
                if (currentFilter === 'lowfuel') return van.lastFuelLevel < 25 && van.status === 'available';
                if (currentFilter === 'blocked') return van.status === 'blocked';
                return van.status === currentFilter;
            });

            filtered.forEach((van, index) => {
                const card = document.createElement('div');
                const isLowFuel = van.lastFuelLevel < 25 && van.status === 'available';
                const isCritical = van.lastFuelLevel < 10 && van.status === 'available';
                const typeInfo = getTypeInfo(van.type);
                const isBlocked = isVehicleBlocked(van);
                
                let borderClass = 'border-green-500';
                let bgClass = '';
                
                if (van.status === 'out') {
                    borderClass = 'border-yellow-500 bg-yellow-50';
                } else if (van.status === 'blocked') {
                    borderClass = 'border-indigo-500 bg-indigo-50';
                } else if (isCritical) {
                    borderClass = 'critical-fuel';
                } else if (isLowFuel) {
                    borderClass = 'border-red-400 bg-red-50';
                }
                
                card.className = `van-card bg-white rounded-2xl p-5 shadow-lg border-4 relative ${borderClass} ${bgClass} ${selectedVanId === van.id ? 'ring-4 ring-yellow-300' : ''} ${reorderMode ? 'admin-mode' : ''}`;
                card.draggable = reorderMode;
                card.dataset.vanId = van.id;
                card.dataset.index = index;
                
                if (reorderMode) {
                    card.addEventListener('dragstart', handleDragStart);
                    card.addEventListener('dragend', handleDragEnd);
                    card.addEventListener('dragover', handleDragOver);
                    card.addEventListener('drop', handleDrop);
                    card.addEventListener('touchstart', handleTouchStart, {passive: false});
                    card.addEventListener('touchend', handleTouchEnd);
                    card.addEventListener('touchmove', handleTouchMove, {passive: false});
                } else {
                    card.onclick = () => selectVan(van.id);
                }
                
                const fuelColor = van.lastFuelLevel > 50 ? 'bg-green-500' : van.lastFuelLevel > 25 ? 'bg-yellow-500' : 'bg-red-500';
                const displayNumber = van.number.length > 8 ? van.number.substring(0, 8) + '...' : van.number;
                
                let statusIcon = '';
                if (van.status === 'out') {
                    statusIcon = '<span class="flex h-4 w-4 relative"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75"></span><span class="relative inline-flex rounded-full h-4 w-4 bg-yellow-500"></span></span>';
                } else if (van.status === 'blocked') {
                    statusIcon = '<i class="fas fa-lock text-indigo-500 text-xl"></i>';
                } else if (isLowFuel) {
                    statusIcon = '<i class="fas fa-gas-pump text-red-500 text-xl animate-pulse"></i>';
                } else {
                    statusIcon = '<i class="fas fa-check-circle text-green-500 text-xl"></i>';
                }
                
                let reservationIndicator = '';
                if (van.reservation) {
                    reservationIndicator = '<div class="time-block-indicator" title="Reserved"></div>';
                }
                
                card.innerHTML = `
                    ${reservationIndicator}
                    <div class="flex justify-between items-start mb-3">
                        <div class="w-14 h-14 ${van.status === 'out' ? 'bg-yellow-500 text-slate-900' : van.status === 'blocked' ? 'bg-indigo-500' : isLowFuel ? 'bg-red-500' : 'bg-green-500'} rounded-2xl flex items-center justify-center text-white font-black text-lg shadow-lg leading-tight text-center p-1">
                            ${displayNumber}
                        </div>
                        <div class="flex flex-col items-end space-y-1">
                            <span class="px-2 py-1 rounded text-xs font-bold text-white ${typeInfo.color}">
                                ${typeInfo.label}
                            </span>
                            ${van.refrigerated ? '<span class="px-2 py-0.5 rounded text-xs font-bold bg-cyan-100 text-cyan-700"><i class="fas fa-snowflake"></i> REF</span>' : ''}
                            ${statusIcon}
                        </div>
                    </div>
                    
                    <h3 class="text-xl font-black text-gray-900 mb-1 leading-tight" title="${van.number}">${van.number}</h3>
                    <div class="text-xs font-bold text-gray-500 mb-2 uppercase tracking-wider flex items-center">
                        <i class="fas ${typeInfo.icon} mr-1"></i> ${typeInfo.label}
                    </div>
                    
                    ${van.reservation ? `
                        <div class="mb-2 px-2 py-1 bg-indigo-100 text-indigo-800 rounded text-xs font-bold truncate">
                            <i class="fas fa-user-clock mr-1"></i> ${van.reservation.driver}
                        </div>
                    ` : ''}
                    
                    <div class="space-y-2">
                        <div class="flex justify-between items-center text-sm font-bold">
                            <span class="text-gray-500 uppercase text-xs">Fuel</span>
                            <span class="${van.lastFuelLevel < 25 ? 'text-red-600' : 'text-gray-900'}">${van.lastFuelLevel}%</span>
                        </div>
                        <div class="h-2.5 bg-gray-200 rounded-full overflow-hidden">
                            <div class="${fuelColor} h-full rounded-full transition-all duration-500" style="width: ${van.lastFuelLevel}%"></div>
                        </div>
                        
                        ${van.status === 'out' ? `
                            <div class="mt-2 pt-2 border-t border-yellow-200">
                                <div class="text-yellow-900 font-bold text-sm truncate">${van.currentDriver}</div>
                                <div class="text-yellow-700 text-xs font-mono">${calculateDuration(van.checkOutTime)}</div>
                            </div>
                        ` : van.status === 'blocked' ? `
                            <div class="mt-2 pt-2 border-t border-indigo-200">
                                <div class="text-indigo-900 font-bold text-sm truncate">${van.reservation?.driver || 'Reserved'}</div>
                                <div class="text-indigo-700 text-xs">${formatTimeBlock(van.reservation?.timeBlock)}</div>
                            </div>
                        ` : isLowFuel ? `
                            <div class="mt-2 pt-2 border-t border-red-200">
                                <div class="text-red-600 font-bold text-xs flex items-center">
                                    <i class="fas fa-exclamation-triangle mr-1"></i>
                                    REFUEL REQUIRED
                                </div>
                            </div>
                        ` : ''}
                    </div>
                `;
                
                grid.appendChild(card);
            });
        }

        function formatTimeBlock(block) {
            if (block === 'morning') return '3 AM - 2 PM';
            if (block === 'evening') return '2 PM - 1 AM';
            if (block === 'allday') return 'All Day';
            return block || 'Reserved';
        }

        // Drag and Drop Handlers (same as before)
        function handleDragStart(e) {
            draggedItem = this;
            this.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/html', this.innerHTML);
        }

        function handleDragEnd(e) {
            this.classList.remove('dragging');
            draggedItem = null;
            document.querySelectorAll('.van-card').forEach(card => card.classList.remove('drag-placeholder'));
        }

        function handleDragOver(e) {
            if (e.preventDefault) e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            
            const afterElement = getDragAfterElement(document.getElementById('fleetGrid'), e.clientY, e.clientX);
            document.querySelectorAll('.van-card').forEach(card => card.classList.remove('drag-placeholder'));
            
            if (afterElement) {
                afterElement.classList.add('drag-placeholder');
            }
            return false;
        }

        function handleDrop(e) {
            if (e.stopPropagation) e.stopPropagation();
            if (draggedItem !== this) {
                const grid = document.getElementById('fleetGrid');
                const afterElement = getDragAfterElement(grid, e.clientY, e.clientX);
                
                if (afterElement == null) {
                    grid.appendChild(draggedItem);
                } else {
                    grid.insertBefore(draggedItem, afterElement);
                }
                
                updateFleetOrder();
            }
            return false;
        }

        let touchDragItem = null;
        let touchOffsetX = 0;
        let touchOffsetY = 0;

        function handleTouchStart(e) {
            const touch = e.touches[0];
            touchDragItem = this;
            const rect = this.getBoundingClientRect();
            touchOffsetX = touch.clientX - rect.left;
            touchOffsetY = touch.clientY - rect.top;
            
            longPressTimer = setTimeout(() => {
                this.classList.add('dragging');
            }, 500);
        }

        function handleTouchMove(e) {
            if (longPressTimer) {
                clearTimeout(longPressTimer);
                longPressTimer = null;
            }
            if (!touchDragItem || !touchDragItem.classList.contains('dragging')) return;
            
            e.preventDefault();
            const touch = e.touches[0];
            const grid = document.getElementById('fleetGrid');
            const afterElement = getDragAfterElement(grid, touch.clientY, touch.clientX);
            
            document.querySelectorAll('.van-card').forEach(card => card.classList.remove('drag-placeholder'));
            if (afterElement && afterElement !== touchDragItem) {
                afterElement.classList.add('drag-placeholder');
            }
        }

        function handleTouchEnd(e) {
            if (longPressTimer) {
                clearTimeout(longPressTimer);
                longPressTimer = null;
            }
            if (!touchDragItem) return;
            
            if (touchDragItem.classList.contains('dragging')) {
                const touch = e.changedTouches[0];
                const grid = document.getElementById('fleetGrid');
                const afterElement = getDragAfterElement(grid, touch.clientY, touch.clientX);
                
                if (afterElement == null) {
                    grid.appendChild(touchDragItem);
                } else {
                    grid.insertBefore(touchDragItem, afterElement);
                }
                
                updateFleetOrder();
            }
            
            touchDragItem.classList.remove('dragging');
            document.querySelectorAll('.van-card').forEach(card => card.classList.remove('drag-placeholder'));
            touchDragItem = null;
        }

        function getDragAfterElement(container, y, x) {
            const draggableElements = [...container.querySelectorAll('.van-card:not(.dragging)')];
            
            return draggableElements.reduce((closest, child) => {
                const box = child.getBoundingClientRect();
                const offsetX = x - box.left - box.width / 2;
                const offsetY = y - box.top - box.height / 2;
                const offset = Math.sqrt(offsetX * offsetX + offsetY * offsetY);
                
                if (offset < closest.offset) {
                    return { offset: offset, element: child };
                } else {
                    return closest;
                }
            }, { offset: Number.POSITIVE_INFINITY }).element;
        }

        function updateFleetOrder() {
            const grid = document.getElementById('fleetGrid');
            const cards = grid.querySelectorAll('.van-card');
            const newOrder = [];
            
            cards.forEach(card => {
                const vanId = parseInt(card.dataset.vanId);
                const van = fleetData.vans.find(v => v.id === vanId);
                if (van) newOrder.push(van);
            });
            
            fleetData.vans = newOrder;
        }

        function toggleReorderMode() {
            reorderMode = !reorderMode;
            const btn = document.getElementById('reorderBtn');
            const hint = document.getElementById('reorderHint');
            
            if (reorderMode) {
                btn.classList.remove('bg-purple-600', 'hover:bg-purple-700');
                btn.classList.add('bg-purple-800', 'hover:bg-purple-900', 'ring-4', 'ring-purple-300');
                hint.classList.remove('hidden');
                showToast('Drag mode enabled - Hold and drag vehicles to reorder', 'success');
            } else {
                btn.classList.add('bg-purple-600', 'hover:bg-purple-700');
                btn.classList.remove('bg-purple-800', 'hover:bg-purple-900', 'ring-4', 'ring-purple-300');
                hint.classList.add('hidden');
            }
            
            renderFleet();
        }

        function saveVehicleOrder() {
            const order = fleetData.vans.map(v => v.id);
            localStorage.setItem('ufs_van_order', JSON.stringify(order));
            saveData();
            reorderMode = false;
            document.getElementById('reorderHint').classList.add('hidden');
            const btn = document.getElementById('reorderBtn');
            btn.classList.add('bg-purple-600', 'hover:bg-purple-700');
            btn.classList.remove('bg-purple-800', 'hover:bg-purple-900', 'ring-4', 'ring-purple-300');
            renderFleet();
            showToast('Vehicle order saved', 'success');
        }

        function cancelReorder() {
            const savedOrder = localStorage.getItem('ufs_van_order');
            if (savedOrder) {
                const order = JSON.parse(savedOrder);
                fleetData.vans.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));
            } else {
                fleetData.vans.sort((a, b) => a.id - b.id);
            }
            reorderMode = false;
            document.getElementById('reorderHint').classList.add('hidden');
            const btn = document.getElementById('reorderBtn');
            btn.classList.add('bg-purple-600', 'hover:bg-purple-700');
            btn.classList.remove('bg-purple-800', 'hover:bg-purple-900', 'ring-4', 'ring-purple-300');
            renderFleet();
        }

        function openReservationModal() {
            const select = document.getElementById('resVehicle');
            select.innerHTML = '';
            
            fleetData.vans.forEach(van => {
                if (van.status === 'available' || van.status === 'blocked') {
                    const option = document.createElement('option');
                    option.value = van.id;
                    option.textContent = `${van.number} - ${getTypeInfo(van.type).label} ${van.status === 'blocked' ? '(Currently Blocked)' : ''}`;
                    if (van.status === 'blocked') option.style.color = '#6366f1';
                    select.appendChild(option);
                }
            });
            
            document.getElementById('reservationModal').classList.remove('hidden');
        }

        function closeReservationModal() {
            document.getElementById('reservationModal').classList.add('hidden');
            document.getElementById('reservationForm').reset();
        }

        document.getElementById('reservationForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const vanId = parseInt(document.getElementById('resVehicle').value);
            const driver = document.getElementById('resDriver').value;
            const timeBlock = document.querySelector('input[name="timeBlock"]:checked').value;
            const notes = document.getElementById('resNotes').value;
            
            const van = fleetData.vans.find(v => v.id === vanId);
            van.status = 'blocked';
            van.reservation = {
                driver: driver,
                timeBlock: timeBlock,
                date: new Date().toISOString(),
                notes: notes
            };
            
            saveData();
            closeReservationModal();
            renderFleet();
            updateStats();
            if (selectedVanId === vanId) selectVan(vanId);
            showToast(`${van.number} blocked for ${driver}`, 'success');
        });

        // ADMIN ONLY - Clear reservation
        function clearReservation() {
            if (!isAdmin) {
                showToast('Admin access required to clear reservations', 'error');
                return;
            }
            if (!selectedVanId) return;
            const van = fleetData.vans.find(v => v.id === selectedVanId);
            if (!van.reservation) return;
            
            if (confirm(`Clear reservation for ${van.number}?`)) {
                van.status = 'available';
                van.reservation = null;
                saveData();
                selectVan(selectedVanId);
                renderFleet();
                updateStats();
                showToast('Reservation cleared', 'success');
            }
        }

        function selectVan(vanId) {
            selectedVanId = vanId;
            const van = fleetData.vans.find(v => v.id === vanId);
            const typeInfo = getTypeInfo(van.type);
            
            document.getElementById('noSelection').classList.add('hidden');
            document.getElementById('vanDetails').classList.remove('hidden');
            
            // Show/hide reservation info
            const resInfo = document.getElementById('reservationInfo');
            const adminClearBtn = document.getElementById('adminClearResBtn');
            
            if (van.reservation && van.status === 'blocked') {
                resInfo.classList.remove('hidden');
                document.getElementById('reservedFor').textContent = van.reservation.driver;
                document.getElementById('reservedTime').textContent = formatTimeBlock(van.reservation.timeBlock);
                document.getElementById('reservationNote').textContent = van.reservation.notes || '';
                
                // Only show clear button if admin is active
                if (isAdmin) {
                    adminClearBtn.classList.remove('hidden');
                } else {
                    adminClearBtn.classList.add('hidden');
                }
            } else {
                resInfo.classList.add('hidden');
            }
            
            document.getElementById('detailVanNumber').textContent = van.number;
            
            const typeBadge = document.getElementById('detailTypeBadge');
            typeBadge.className = `px-3 py-1 rounded-full text-xs font-bold text-white ${typeInfo.color}`;
            typeBadge.textContent = typeInfo.label;
            
            const fuelBadge = document.getElementById('fuelTypeBadge');
            fuelBadge.textContent = van.fuelType;
            if (van.fuelType.includes('Propane')) {
                fuelBadge.className = 'fuel-type-badge px-2 py-1 rounded bg-orange-100 text-orange-700 font-bold uppercase';
            } else if (van.fuelType === 'Diesel') {
                fuelBadge.className = 'fuel-type-badge px-2 py-1 rounded bg-gray-700 text-white font-bold uppercase';
            } else {
                fuelBadge.className = 'fuel-type-badge px-2 py-1 rounded bg-blue-100 text-blue-700 font-bold uppercase';
            }
            
            document.getElementById('vehicleTypeText').textContent = typeInfo.label;
            document.getElementById('vehicleTypeDesc').textContent = van.desc;
            document.getElementById('detailFuelType').textContent = van.fuelType;
            document.getElementById('detailCapacity').textContent = van.seats ? `${van.seats} seats` : 'Cargo Only';
            
            if (van.length) {
                document.getElementById('lengthRow').classList.remove('hidden');
                document.getElementById('detailLength').textContent = van.length;
            } else {
                document.getElementById('lengthRow').classList.add('hidden');
            }
            
            if (van.logo && van.logo !== 'Standard') {
                document.getElementById('logoRow').classList.remove('hidden');
                document.getElementById('detailLogo').textContent = van.logo;
            } else {
                document.getElementById('logoRow').classList.add('hidden');
            }
            
            const statusBadge = document.getElementById('detailStatusBadge');
            const keyIcon = document.getElementById('keyStatusIcon');
            const actionButtons = document.getElementById('actionButtons');
            const lastDriverInfo = document.getElementById('lastDriverInfo');
            const quickRefuelBtn = document.getElementById('quickRefuelBtn');
            
            document.getElementById('fuelPercentage').textContent = van.lastFuelLevel + '%';
            document.getElementById('fuelBar').style.width = van.lastFuelLevel + '%';
            
            const fuelPercentEl = document.getElementById('fuelPercentage');
            const fuelBar = document.getElementById('fuelBar');
            if (van.lastFuelLevel < 25) {
                fuelPercentEl.className = 'text-3xl font-black text-red-600';
                fuelBar.className = 'h-full rounded-full transition-all duration-500 bg-red-500';
                quickRefuelBtn.classList.remove('hidden');
            } else if (van.lastFuelLevel < 50) {
                fuelPercentEl.className = 'text-3xl font-black text-yellow-600';
                fuelBar.className = 'h-full rounded-full transition-all duration-500 bg-yellow-500';
                quickRefuelBtn.classList.add('hidden');
            } else {
                fuelPercentEl.className = 'text-3xl font-black text-green-600';
                fuelBar.className = 'h-full rounded-full transition-all duration-500 bg-green-500';
                quickRefuelBtn.classList.add('hidden');
            }
            
            if (van.status === 'out') {
                statusBadge.className = 'px-4 py-1 rounded-full text-sm font-bold bg-yellow-100 text-yellow-800';
                statusBadge.textContent = 'OUT ON DELIVERY';
                keyIcon.className = 'w-20 h-20 rounded-2xl bg-yellow-500 flex items-center justify-center text-slate-900 text-3xl shadow-lg';
                keyIcon.innerHTML = '<i class="fas fa-road"></i>';
                quickRefuelBtn.classList.add('hidden');
                resInfo.classList.add('hidden');
                
                lastDriverInfo.classList.remove('hidden');
                document.getElementById('currentDriverName').textContent = van.currentDriver;
                document.getElementById('checkOutTime').textContent = new Date(van.checkOutTime).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                document.getElementById('tripDuration').textContent = calculateDuration(van.checkOutTime);
                
                actionButtons.innerHTML = `
                    <button onclick="openCheckInModal(${van.id})" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl text-xl shadow-lg transition flex items-center justify-center space-x-3">
                        <i class="fas fa-undo"></i>
                        <span>Return Keys / Check In</span>
                    </button>
                `;
            } else if (van.status === 'blocked') {
                statusBadge.className = 'px-4 py-1 rounded-full text-sm font-bold bg-indigo-100 text-indigo-800';
                statusBadge.textContent = 'BLOCKED/RESERVED';
                keyIcon.className = 'w-20 h-20 rounded-2xl bg-indigo-500 flex items-center justify-center text-white text-3xl shadow-lg';
                keyIcon.innerHTML = '<i class="fas fa-lock"></i>';
                quickRefuelBtn.classList.add('hidden');
                lastDriverInfo.classList.add('hidden');
                
                // Regular users see blocked message, no action buttons
                // Admin sees clear button in the reservation info section above
                actionButtons.innerHTML = `
                    <div class="bg-indigo-50 border-2 border-indigo-300 rounded-xl p-4">
                        <div class="text-indigo-800 font-bold mb-2"><i class="fas fa-lock mr-2"></i>Vehicle Reserved</div>
                        <div class="text-indigo-700 text-sm">Assigned to: ${van.reservation?.driver || 'Unknown'}</div>
                        <div class="text-indigo-700 text-sm">Time: ${formatTimeBlock(van.reservation?.timeBlock)}</div>
                        ${!isAdmin ? '<div class="text-indigo-600 text-sm mt-2 italic">Contact admin to clear reservation</div>' : ''}
                    </div>
                `;
            } else {
                const isLowFuel = van.lastFuelLevel < 25;
                statusBadge.className = `px-4 py-1 rounded-full text-sm font-bold ${isLowFuel ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800'}`;
                statusBadge.textContent = isLowFuel ? 'NEEDS FUEL' : 'AVAILABLE';
                keyIcon.className = `w-20 h-20 rounded-2xl ${isLowFuel ? 'bg-red-500' : 'key-present'} flex items-center justify-center text-white text-3xl shadow-lg`;
                keyIcon.innerHTML = '<i class="fas fa-key"></i>';
                
                lastDriverInfo.classList.add('hidden');
                resInfo.classList.add('hidden');
                
                if (isLowFuel) {
                    actionButtons.innerHTML = `
                        <div class="bg-red-50 border-2 border-red-300 rounded-xl p-4 mb-4">
                            <div class="text-red-800 font-bold mb-2"><i class="fas fa-ban mr-2"></i>Cannot Check Out</div>
                            <div class="text-red-700 text-sm">Vehicle must be refueled first</div>
                        </div>
                    `;
                } else {
                    actionButtons.innerHTML = `
                        <button onclick="openCheckOutModal(${van.id})" class="w-full bg-yellow-500 hover:bg-yellow-400 text-slate-900 font-bold py-4 rounded-xl text-xl shadow-lg transition flex items-center justify-center space-x-3">
                            <i class="fas fa-key"></i>
                            <span>Check Out Vehicle</span>
                        </button>
                    `;
                }
            }
            
            if (!reorderMode) renderFleet();
        }

        function closeDetails() {
            selectedVanId = null;
            document.getElementById('noSelection').classList.remove('hidden');
            document.getElementById('vanDetails').classList.add('hidden');
            if (!reorderMode) renderFleet();
        }

        function quickRefuel() {
            if (!selectedVanId) return;
            const van = fleetData.vans.find(v => v.id === selectedVanId);
            van.lastFuelLevel = 100;
            saveData();
            selectVan(selectedVanId);
            renderFleet();
            updateStats();
            checkFuelAlerts();
            showToast(`${van.number} refueled to 100%`, 'success');
        }

        function toggleAdminPanel() {
            const panel = document.getElementById('adminPanel');
            if (panel.classList.contains('hidden')) {
                const password = prompt('Enter admin password:');
                if (password === 'ufs2024') {
                    isAdmin = true;
                    panel.classList.remove('hidden');
                    // Refresh details view if a vehicle is selected to show admin controls
                    if (selectedVanId) selectVan(selectedVanId);
                } else if (password) {
                    showToast('Incorrect password', 'error');
                }
            } else {
                panel.classList.add('hidden');
                isAdmin = false;
                if (reorderMode) cancelReorder();
                // Refresh details view to hide admin controls
                if (selectedVanId) selectVan(selectedVanId);
            }
        }

        function adminResetAllFuel() {
            if (!isAdmin) return;
            if (confirm('Reset ALL 16 vehicles to 100% fuel?')) {
                fleetData.vans.forEach(v => v.lastFuelLevel = 100);
                saveData();
                renderFleet();
                updateStats();
                checkFuelAlerts();
                if (selectedVanId) selectVan(selectedVanId);
                showToast('All vehicles refueled', 'success');
            }
        }

        function adminClearLogs() {
            if (!isAdmin) return;
            if (confirm('WARNING: Delete ALL trip history?')) {
                fleetData.logs = [];
                saveData();
                loadLogs();
                updateStats();
                showToast('All logs cleared', 'success');
            }
        }

        function openCheckOutModal(vanId) {
            selectedVanId = vanId;
            const van = fleetData.vans.find(v => v.id === vanId);
            const typeInfo = getTypeInfo(van.type);
            
            document.getElementById('modalVanTitle').textContent = van.number;
            document.getElementById('modalVanType').textContent = `${typeInfo.label} - ${van.fuelType}`;
            document.getElementById('modalFuelSlider').value = van.lastFuelLevel;
            updateModalFuel(van.lastFuelLevel);
            document.getElementById('checkOutModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('checkOutModal').classList.add('hidden');
            document.getElementById('checkOutForm').reset();
        }

        function updateModalFuel(value) {
            document.getElementById('modalFuelPercent').textContent = value + '%';
            const el = document.getElementById('modalFuelPercent');
            if (value < 25) el.className = 'text-3xl font-black text-red-600';
            else if (value < 50) el.className = 'text-3xl font-black text-yellow-600';
            else el.className = 'text-3xl font-black text-green-600';
        }

        document.getElementById('checkOutForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const van = fleetData.vans.find(v => v.id === selectedVanId);
            
            van.status = 'out';
            van.currentDriver = document.getElementById('modalDriver').value;
            van.purpose = document.getElementById('modalPurpose').value;
            van.destination = document.getElementById('modalDestination').value;
            van.checkOutTime = new Date().toISOString();
            van.fuelAtCheckOut = parseInt(document.getElementById('modalFuelSlider').value);
            
            const logEntry = {
                id: Date.now(),
                vanId: van.id,
                vanNumber: van.number,
                vanType: van.type,
                driver: van.currentDriver,
                purpose: van.purpose,
                destination: van.destination,
                checkOut: van.checkOutTime,
                checkIn: null,
                fuelOut: van.fuelAtCheckOut,
                fuelIn: null,
                date: new Date().toDateString()
            };
            
            fleetData.logs.unshift(logEntry);
            saveData();
            closeModal();
            
            showToast(`${van.number} checked out`, 'success');
            selectVan(van.id);
            renderFleet();
            loadLogs();
            updateStats();
        });

        function openCheckInModal(vanId) {
            selectedVanId = vanId;
            const van = fleetData.vans.find(v => v.id === vanId);
            
            document.getElementById('checkInVanTitle').textContent = van.number;
            document.getElementById('checkInDriver').textContent = van.currentDriver;
            document.getElementById('checkInDuration').textContent = calculateDuration(van.checkOutTime);
            
            // 17% fuel estimation
            const estimatedFuel = Math.max(10, (van.fuelAtCheckOut || 100) - 17);
            document.getElementById('checkInFuelSlider').value = estimatedFuel;
            updateCheckInFuel(estimatedFuel);
            
            document.getElementById('checkInModal').classList.remove('hidden');
        }

        function closeCheckInModal() {
            document.getElementById('checkInModal').classList.add('hidden');
        }

        function updateCheckInFuel(value) {
            document.getElementById('checkInFuelPercent').textContent = value + '%';
            const alertBox = document.getElementById('fuelAlertBox');
            
            if (parseInt(value) < 25) {
                alertBox.classList.remove('hidden');
                document.getElementById('checkInFuelPercent').className = 'text-3xl font-black text-red-600';
            } else {
                alertBox.classList.add('hidden');
                document.getElementById('checkInFuelPercent').className = parseInt(value) < 50 ? 'text-3xl font-black text-yellow-600' : 'text-3xl font-black text-green-600';
            }
        }

        document.getElementById('checkInForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const van = fleetData.vans.find(v => v.id === selectedVanId);
            const fuelIn = parseInt(document.getElementById('checkInFuelSlider').value);
            
            const logEntry = fleetData.logs.find(l => l.vanId === selectedVanId && !l.checkIn);
            if (logEntry) {
                logEntry.checkIn = new Date().toISOString();
                logEntry.fuelIn = fuelIn;
                logEntry.duration = Math.floor((new Date() - new Date(logEntry.checkOut)) / 1000 / 60);
            }
            
            van.status = 'available';
            van.lastFuelLevel = fuelIn;
            van.currentDriver = null;
            van.checkOutTime = null;
            van.fuelAtCheckOut = null;
            
            saveData();
            closeCheckInModal();
            
            const fuelMsg = fuelIn < 25 ? ' - Low Fuel' : '';
            showToast(`${van.number} returned${fuelMsg}`, fuelIn < 25 ? 'warning' : 'success');
            selectVan(van.id);
            renderFleet();
            loadLogs();
            updateStats();
            checkFuelAlerts();
        });

        function calculateDuration(startTime) {
            const diff = Math.floor((new Date() - new Date(startTime)) / 1000 / 60);
            const hours = Math.floor(diff / 60);
            const mins = diff % 60;
            return hours > 0 ? `${hours}h ${mins}m` : `${mins}m`;
        }

        function loadLogs() {
            const tbody = document.getElementById('logTableBody');
            const today = new Date().toDateString();
            const dayLogs = fleetData.logs.filter(l => new Date(l.checkOut).toDateString() === today);
            
            tbody.innerHTML = '';
            
            if (dayLogs.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-gray-400">
                            <i class="fas fa-clipboard-list text-5xl mb-4 opacity-30"></i>
                            <p class="text-xl font-semibold">No activity today</p>
                        </td>
                    </tr>
                `;
                return;
            }

            dayLogs.forEach(log => {
                const isActive = !log.checkIn;
                const typeInfo = getTypeInfo(log.vanType || 'low');
                const row = document.createElement('tr');
                row.className = 'hover:bg-gray-50 transition border-b border-gray-100';
                
                row.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="font-bold text-gray-900">${new Date(log.checkOut).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</div>
                        ${log.checkIn ? `<div class="text-sm text-gray-500">→ ${new Date(log.checkIn).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</div>` : ''}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap font-bold text-lg text-gray-900">${log.vanNumber}</td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 py-1 rounded text-xs font-bold text-white ${typeInfo.color}">
                            ${typeInfo.label}
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap font-semibold text-gray-900">${log.driver}</td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-3 py-1 rounded-full text-sm font-bold bg-gray-100 text-gray-700">${log.purpose}</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center space-x-2">
                            <div class="w-8 h-2 bg-gray-200 rounded-full overflow-hidden">
                                <div class="h-full ${log.fuelOut > 50 ? 'bg-green-500' : log.fuelOut > 25 ? 'bg-yellow-500' : 'bg-red-500'}" style="width: ${log.fuelOut}%"></div>
                            </div>
                            <span class="text-xs font-bold">${log.fuelOut}%</span>
                            ${log.fuelIn !== null ? `
                                <i class="fas fa-arrow-right text-gray-400 text-xs"></i>
                                <div class="w-8 h-2 bg-gray-200 rounded-full overflow-hidden">
                                    <div class="h-full ${log.fuelIn > 50 ? 'bg-green-500' : log.fuelIn > 25 ? 'bg-yellow-500' : 'bg-red-500'}" style="width: ${log.fuelIn}%"></div>
                                </div>
                                <span class="text-xs font-bold">${log.fuelIn}%</span>
                            ` : ''}
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold ${isActive ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800'}">
                            ${isActive ? '<span class="w-2 h-2 bg-yellow-500 rounded-full mr-2 animate-pulse"></span> Out' : 'Done'}
                        </span>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        function updateStats() {
            const available = fleetData.vans.filter(v => v.status === 'available').length;
            const out = fleetData.vans.filter(v => v.status === 'out').length;
            const blocked = fleetData.vans.filter(v => v.status === 'blocked').length;
            const lowFuel = fleetData.vans.filter(v => v.lastFuelLevel < 25 && v.status === 'available').length;
            const today = new Date().toDateString();
            const todayLogs = fleetData.logs.filter(l => new Date(l.checkOut).toDateString() === today);
            
            document.getElementById('availableCount').textContent = available;
            document.getElementById('outCount').textContent = out;
            document.getElementById('blockedCount').textContent = blocked;
            document.getElementById('todayTrips').textContent = todayLogs.length;
            document.getElementById('lowFuelCount').textContent = lowFuel;
            
            const totalMinutes = todayLogs.reduce((acc, log) => {
                if (log.duration) return acc + log.duration;
                if (!log.checkIn) return acc + Math.floor((new Date() - new Date(log.checkOut)) / 1000 / 60);
                return acc;
            }, 0);
            
            document.getElementById('activeHours').textContent = (totalMinutes / 60).toFixed(1);
        }

        function checkFuelAlerts() {
            const lowFuelVans = fleetData.vans.filter(v => v.lastFuelLevel < 25 && v.status === 'available');
            const alertBanner = document.getElementById('fuelAlerts');
            
            if (lowFuelVans.length > 0) {
                alertBanner.classList.remove('hidden');
                const names = lowFuelVans.map(v => v.number).join(', ');
                document.getElementById('fuelAlertText').textContent = 
                    names.length > 50 ? names.substring(0, 50) + '... need fuel' : names + ' need fuel';
            } else {
                alertBanner.classList.add('hidden');
            }
        }

        function dismissFuelAlert() {
            document.getElementById('fuelAlerts').classList.add('hidden');
        }

        function filterLowFuel() {
            currentFilter = 'lowfuel';
            updateFilterButtons();
            renderFleet();
        }

        function filterVans(type) {
            currentFilter = type;
            updateFilterButtons();
            renderFleet();
        }

        function updateFilterButtons() {
            document.querySelectorAll('[id^="filter-"]').forEach(btn => {
                const btnType = btn.id.replace('filter-', '');
                if (btnType === currentFilter) {
                    btn.className = 'px-6 py-3 rounded-lg font-bold text-lg bg-yellow-500 text-slate-900 shadow-md transition';
                } else {
                    btn.className = 'px-6 py-3 rounded-lg font-bold text-lg text-gray-600 hover:bg-gray-100 transition';
                }
            });
        }

        function saveData() {
            localStorage.setItem('ufs_vans', JSON.stringify(fleetData.vans));
            localStorage.setItem('ufs_logs', JSON.stringify(fleetData.logs));
        }

        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const title = document.getElementById('toastTitle');
            const msg = document.getElementById('toastMessage');
            
            msg.textContent = message;
            
            if (type === 'error') {
                icon.innerHTML = '<i class="fas fa-exclamation-circle text-red-400"></i>';
                title.textContent = 'Error';
                title.className = 'font-bold text-xl text-red-400';
            } else if (type === 'warning') {
                icon.innerHTML = '<i class="fas fa-exclamation-triangle text-yellow-400"></i>';
                title.textContent = 'Warning';
                title.className = 'font-bold text-xl text-yellow-400';
            } else {
                icon.innerHTML = '<i class="fas fa-check-circle text-green-400"></i>';
                title.textContent = 'Success';
                title.className = 'font-bold text-xl text-green-400';
            }
            
            toast.classList.remove('translate-y-32', 'opacity-0');
            
            setTimeout(() => {
                toast.classList.add('translate-y-32', 'opacity-0');
            }, 4000);
        }

        function exportData() {
            const date = new Date().toISOString().split('T')[0];
            const csvContent = [
                ['Date', 'Vehicle', 'Type', 'Fuel Type', 'Driver', 'Purpose', 'Destination', 'Check Out', 'Check In', 'Duration (min)', 'Fuel Out %', 'Fuel In %'].join(','),
                ...fleetData.logs.map(log => {
                    const van = fleetData.vans.find(v => v.id === log.vanId) || {};
                    return [
                        new Date(log.checkOut).toLocaleDateString(),
                        log.vanNumber,
                        getTypeInfo(log.vanType || 'low').label,
                        van.fuelType || '',
                        log.driver,
                        log.purpose,
                        log.destination || '',
                        new Date(log.checkOut).toLocaleString(),
                        log.checkIn ? new Date(log.checkIn).toLocaleString() : 'Active',
                        log.duration || 'In Progress',
                        log.fuelOut,
                        log.fuelIn !== null ? log.fuelIn : 'N/A'
                    ].join(',');
                })
            ].join('\n');

            const blob = new Blob([csvContent], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `ufs-fleet-log-${date}.csv`;
            a.click();
            showToast('CSV exported');
        }

        if ('wakeLock' in navigator) {
            navigator.wakeLock.request('screen').catch(err => console.log('Wake lock failed:', err));
        }
    </script>
</body>
</html>
