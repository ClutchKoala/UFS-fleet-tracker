<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>UFS Fleet & Fuel Tracker</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Inter', sans-serif; 
            touch-action: manipulation;
            -webkit-touch-callout: none;
            -webkit-user-select: none;
            user-select: none;
        }
        .fuel-gauge {
            background: linear-gradient(to right, #ef4444 0%, #eab308 50%, #22c55e 100%);
            height: 100%;
            border-radius: 9999px;
            transition: width 0.5s ease;
        }
        .pulse-alert {
            animation: pulseRed 2s infinite;
        }
        @keyframes pulseRed {
            0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
            50% { box-shadow: 0 0 0 20px rgba(239, 68, 68, 0); }
        }
        .slide-up {
            animation: slideUp 0.4s ease-out;
        }
        @keyframes slideUp {
            from { transform: translateY(100%); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .van-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
        }
        .van-card:active {
            transform: scale(0.98);
        }
        .van-card.dragging {
            opacity: 0.5;
            transform: scale(1.05);
            z-index: 1000;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }
        .van-card.admin-mode {
            cursor: move;
            position: relative;
        }
        .van-card.admin-mode::after {
            content: '\f0c9';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            top: 8px;
            right: 8px;
            color: rgba(255,255,255,0.8);
            font-size: 1.2rem;
            background: rgba(0,0,0,0.3);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .fuel-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 12px;
            border-radius: 6px;
            background: linear-gradient(to right, #ef4444 0%, #eab308 50%, #22c55e 100%);
            outline: none;
        }
        .fuel-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: white;
            border: 3px solid #4b5563;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .critical-fuel {
            background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
            border: 2px solid #ef4444;
            animation: borderPulse 2s infinite;
        }
        @keyframes borderPulse {
            0%, 100% { border-color: #ef4444; }
            50% { border-color: #f87171; }
        }
        .key-present {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            box-shadow: 0 0 20px rgba(34, 197, 94, 0.5);
        }
        .key-hook {
            background: linear-gradient(135deg, #374151 0%, #1f2937 100%);
        }
        .admin-btn {
            transition: all 0.2s;
        }
        .admin-btn:active {
            transform: scale(0.95);
        }
        /* Vehicle type badges */
        .type-people { background: linear-gradient(135deg, #db2777 0%, #be185d 100%); }
        .type-box { background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%); }
        .type-refrigerated { background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%); }
        .type-low { background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); }
        .type-high { background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%); }
        .type-ppl-cargo { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
        .type-small { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
        
        .fuel-type-badge {
            font-size: 0.65rem;
            letter-spacing: 0.05em;
        }
        
        .time-block-indicator {
            position: absolute;
            bottom: 4px;
            left: 4px;
            right: 4px;
            height: 4px;
            background: rgba(99, 102, 241, 0.8);
            border-radius: 2px;
        }
        
        .drag-placeholder {
            background: rgba(234, 179, 8, 0.2);
            border: 2px dashed #eab308;
            border-radius: 1rem;
        }
    </style>
</head>
<body class="bg-gray-100 text-lg">

    <!-- Header -->
    <nav class="bg-slate-900 text-white shadow-2xl sticky top-0 z-50 border-b-4 border-yellow-500">
        <div class="max-w-7xl mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <div class="bg-yellow-500 p-3 rounded-xl shadow-lg">
                        <i class="fas fa-truck-moving text-3xl text-slate-900"></i>
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold tracking-tight">UTAH FOOD SERVICES</h1>
                        <p class="text-yellow-400 font-semibold text-lg">Fleet & Fuel Management</p>
                    </div>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="bg-slate-800 px-6 py-3 rounded-xl border border-slate-700">
                        <div class="text-slate-400 text-sm uppercase tracking-wider font-bold">Current Time</div>
                        <div id="currentTime" class="text-3xl font-mono font-bold text-white"></div>
                    </div>
                    <button onclick="toggleAdminPanel()" class="bg-slate-700 hover:bg-slate-600 p-4 rounded-xl transition border border-slate-600" title="Admin Settings">
                        <i class="fas fa-cog text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Admin Panel -->
    <div id="adminPanel" class="hidden bg-slate-800 text-white border-b border-slate-700 shadow-lg">
        <div class="max-w-7xl mx-auto px-6 py-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-2xl font-bold text-yellow-400"><i class="fas fa-lock mr-2"></i>Admin Panel</h2>
                <button onclick="toggleAdminPanel()" class="text-slate-400 hover:text-white text-2xl">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-4">
                <button onclick="adminResetAllFuel()" class="admin-btn bg-green-600 hover:bg-green-700 p-4 rounded-xl text-left">
                    <i class="fas fa-gas-pump text-2xl mb-2 block"></i>
                    <div class="font-bold">Refuel All</div>
                </button>
                
                <button onclick="toggleReorderMode()" id="reorderBtn" class="admin-btn bg-purple-600 hover:bg-purple-700 p-4 rounded-xl text-left">
                    <i class="fas fa-arrows-alt text-2xl mb-2 block"></i>
                    <div class="font-bold">Reorder Vehicles</div>
                    <div class="text-sm text-purple-200">Drag to rearrange</div>
                </button>
                
                <button onclick="openReservationModal()" class="admin-btn bg-indigo-600 hover:bg-indigo-700 p-4 rounded-xl text-left">
                    <i class="fas fa-calendar-check text-2xl mb-2 block"></i>
                    <div class="font-bold">Block/Reserve</div>
                    <div class="text-sm text-indigo-200">Assign driver & time</div>
                </button>
                
                <button onclick="adminClearLogs()" class="admin-btn bg-red-600 hover:bg-red-700 p-4 rounded-xl text-left">
                    <i class="fas fa-trash-alt text-2xl mb-2 block"></i>
                    <div class="font-bold">Clear Logs</div>
                </button>
            </div>
            
            <div id="reorderHint" class="hidden bg-purple-900 rounded-xl p-4 text-purple-200 text-center">
                <i class="fas fa-hand-pointer mr-2"></i> Hold and drag vehicles to reorder. Click "Save Order" when done.
                <button onclick="saveVehicleOrder()" class="ml-4 bg-purple-500 hover:bg-purple-400 text-white px-4 py-2 rounded-lg font-bold">Save Order</button>
                <button onclick="cancelReorder()" class="ml-2 bg-slate-600 hover:bg-slate-500 text-white px-4 py-2 rounded-lg">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Fuel Alerts Banner -->
    <div id="fuelAlerts" class="hidden bg-red-600 text-white px-6 py-4 shadow-lg">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <i class="fas fa-gas-pump text-3xl animate-bounce"></i>
                <div>
                    <h3 class="text-xl font-bold">LOW FUEL ALERT</h3>
                    <p class="text-red-100" id="fuelAlertText">Vehicles need refueling</p>
                </div>
            </div>
            <button onclick="dismissFuelAlert()" class="bg-red-700 hover:bg-red-800 px-6 py-2 rounded-lg font-bold">
                Dismiss
            </button>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-8 space-y-6">

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
            <div class="bg-white rounded-2xl shadow-lg p-6 border-l-8 border-green-500">
                <div class="text-gray-500 font-bold text-sm uppercase">Available</div>
                <div class="text-5xl font-black text-gray-900 mt-2" id="availableCount">0</div>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-6 border-l-8 border-yellow-500">
                <div class="text-gray-500 font-bold text-sm uppercase">Out Now</div>
                <div class="text-5xl font-black text-gray-900 mt-2" id="outCount">0</div>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-6 border-l-8 border-indigo-500">
                <div class="text-gray-500 font-bold text-sm uppercase">Blocked</div>
                <div class="text-5xl font-black text-indigo-600 mt-2" id="blockedCount">0</div>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-6 border-l-8 border-orange-500">
                <div class="text-gray-500 font-bold text-sm uppercase">Today's Trips</div>
                <div class="text-5xl font-black text-gray-900 mt-2" id="todayTrips">0</div>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-6 border-l-8 border-red-500 cursor-pointer hover:bg-red-50 transition" onclick="filterLowFuel()">
                <div class="text-gray-500 font-bold text-sm uppercase">Need Fuel</div>
                <div class="text-5xl font-black text-red-600 mt-2" id="lowFuelCount">0</div>
            </div>
        </div>

        <!-- Main Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Vehicle Selection -->
            <div class="lg:col-span-2 space-y-4">
                <div class="flex justify-between items-center">
                    <h2 class="text-2xl font-bold text-gray-900">
                        <i class="fas fa-th-large text-yellow-500 mr-3"></i>
                        Select Vehicle
                    </h2>
                    <div class="flex space-x-2 bg-white p-1 rounded-xl shadow-sm">
                        <button onclick="filterVans('all')" id="filter-all" class="px-6 py-3 rounded-lg font-bold text-lg bg-yellow-500 text-slate-900 shadow-md transition">All</button>
                        <button onclick="filterVans('available')" id="filter-available" class="px-6 py-3 rounded-lg font-bold text-lg text-gray-600 hover:bg-gray-100 transition">Available</button>
                        <button onclick="filterVans('out')" id="filter-out" class="px-6 py-3 rounded-lg font-bold text-lg text-gray-600 hover:bg-gray-100 transition">Out</button>
                        <button onclick="filterVans('blocked')" id="filter-blocked" class="px-6 py-3 rounded-lg font-bold text-lg text-gray-600 hover:bg-gray-100 transition">Blocked</button>
                    </div>
                </div>

                <div id="fleetGrid" class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    <!-- Vehicle cards -->
                </div>
            </div>

            <!-- Side Panel -->
            <div class="lg:col-span-1">
                <div id="selectedVanPanel" class="bg-white rounded-2xl shadow-xl border-2 border-gray-200 overflow-hidden sticky top-24">
                    <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                        <h3 class="text-xl font-bold text-gray-900">Vehicle Details</h3>
                        <button onclick="closeDetails()" class="text-gray-400 hover:text-gray-600 text-xl">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    
                    <div id="noSelection" class="p-12 text-center text-gray-400">
                        <i class="fas fa-hand-pointer text-6xl mb-4 opacity-30"></i>
                        <p class="text-xl font-semibold">Tap a vehicle to view details</p>
                    </div>

                    <div id="vanDetails" class="hidden">
                        <div class="p-6 space-y-6">
                            <div class="flex justify-between items-start">
                                <div class="flex-1">
                                    <div class="text-4xl font-black text-gray-900 mb-1 leading-tight" id="detailVanNumber">Vehicle</div>
                                    <div class="flex flex-wrap items-center gap-2 mt-2">
                                        <span id="detailStatusBadge" class="px-4 py-1 rounded-full text-sm font-bold bg-green-100 text-green-800">
                                            AVAILABLE
                                        </span>
                                        <span id="detailTypeBadge" class="px-3 py-1 rounded-full text-xs font-bold text-white type-low">
                                            TYPE
                                        </span>
                                        <span id="fuelTypeBadge" class="fuel-type-badge px-2 py-1 rounded bg-gray-200 text-gray-700 font-bold uppercase">
                                            FUEL
                                        </span>
                                    </div>
                                </div>
                                <div id="keyStatusIcon" class="w-20 h-20 rounded-2xl key-hook flex items-center justify-center text-white text-3xl shadow-lg flex-shrink-0">
                                    <i class="fas fa-key"></i>
                                </div>
                            </div>

                            <!-- Reservation Info (if blocked) - NO CLEAR BUTTON HERE -->
                            <div id="reservationInfo" class="hidden bg-indigo-50 rounded-xl p-4 border border-indigo-200">
                                <div class="text-indigo-800 font-bold mb-2"><i class="fas fa-lock mr-2"></i>Reserved/Blocked</div>
                                <div class="text-indigo-900 font-semibold" id="reservedFor">Driver Name</div>
                                <div class="text-indigo-700 text-sm mt-1" id="reservedTime">Time Block</div>
                                <div class="text-indigo-600 text-sm mt-2 italic" id="reservationNote"></div>
                                <!-- Clear button only shows for admin - handled in JS -->
                                <button id="adminClearResBtn" onclick="clearReservation()" class="hidden mt-3 w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2 rounded-lg font-bold text-sm">
                                    <i class="fas fa-unlock mr-2"></i>Admin: Clear Reservation
                                </button>
                            </div>

                            <!-- Vehicle Info -->
                            <div class="bg-gray-50 rounded-xl p-4 border border-gray-200">
                                <div class="flex justify-between items-center mb-2">
                                    <span class="font-bold text-gray-700">Vehicle Type</span>
                                    <span id="vehicleTypeText" class="font-bold text-blue-600">Type</span>
                                </div>
                                <div class="text-sm text-gray-500 mb-3" id="vehicleTypeDesc">Description</div>
                                
                                <div class="border-t border-gray-200 pt-3 space-y-2 text-sm">
                                    <div class="flex justify-between">
                                        <span class="text-gray-600">Fuel Type:</span>
                                        <span id="detailFuelType" class="font-bold text-gray-900">Fuel</span>
                                    </div>
                                    <div class="flex justify-between">
                                        <span class="text-gray-600">Capacity:</span>
                                        <span id="detailCapacity" class="font-bold text-gray-900">Capacity</span>
                                    </div>
                                    <div class="flex justify-between" id="lengthRow">
                                        <span class="text-gray-600">Length:</span>
                                        <span id="detailLength" class="font-bold text-gray-900">Length</span>
                                    </div>
                                    <div class="flex justify-between hidden" id="logoRow">
                                        <span class="text-gray-600">Branding:</span>
                                        <span id="detailLogo" class="font-bold text-gray-900">Logo</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Fuel Section -->
                            <div class="bg-gray-50 rounded-xl p-4 border-2 border-gray-200">
                                <div class="flex justify-between items-center mb-3">
                                    <span class="font-bold text-gray-700 text-lg">Fuel Level</span>
                                    <span id="fuelPercentage" class="text-3xl font-black text-green-600">100%</span>
                                </div>
                                <div class="h-6 bg-gray-200 rounded-full overflow-hidden relative">
                                    <div id="fuelBar" class="fuel-gauge" style="width: 100%"></div>
                                </div>
                                
                                <button onclick="quickRefuel()" id="quickRefuelBtn" class="w-full mt-4 bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl shadow-lg transition flex items-center justify-center space-x-2">
                                    <i class="fas fa-gas-pump"></i>
                                    <span>Refuel to 100%</span>
                                </button>
                            </div>

                            <div id="lastDriverInfo" class="hidden bg-yellow-50 rounded-xl p-4 border border-yellow-200">
                                <div class="text-yellow-800 font-bold mb-2"><i class="fas fa-user-clock mr-2"></i>Currently Out</div>
                                <div class="text-yellow-900 text-lg font-semibold" id="currentDriverName">Driver</div>
                                <div class="text-yellow-700 text-sm mt-1">Out: <span id="checkOutTime">Time</span></div>
                                <div class="text-yellow-700 text-sm">Duration: <span id="tripDuration" class="font-mono font-bold">Duration</span></div>
                            </div>

                            <div class="space-y-3" id="actionButtons">
                                <!-- Dynamic buttons -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Activity Log -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
                <h2 class="text-xl font-bold text-gray-900">
                    <i class="fas fa-history text-yellow-500 mr-3"></i>
                    Today's Activity Log
                </h2>
                <button onclick="exportData()" class="bg-gray-800 hover:bg-gray-700 text-white px-6 py-3 rounded-xl font-bold transition">
                    <i class="fas fa-download mr-2"></i>Export CSV
                </button>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-100 text-gray-600 text-sm uppercase tracking-wider">
                        <tr>
                            <th class="px-6 py-4 font-bold">Time</th>
                            <th class="px-6 py-4 font-bold">Vehicle</th>
                            <th class="px-6 py-4 font-bold">Type</th>
                            <th class="px-6 py-4 font-bold">Driver</th>
                            <th class="px-6 py-4 font-bold">Purpose</th>
                            <th class="px-6 py-4 font-bold">Fuel</th>
                            <th class="px-6 py-4 font-bold">Status</th>
                        </tr>
                    </thead>
                    <tbody id="logTableBody" class="divide-y divide-gray-200 text-lg">
                        <!-- Logs -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Check-Out Modal -->
    <div id="checkOutModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white rounded-3xl shadow-2xl max-w-lg w-full slide-up">
            <div class="bg-yellow-500 text-slate-900 px-8 py-6 flex justify-between items-center">
                <div>
                    <h3 class="text-3xl font-bold">Check Out</h3>
                    <p class="text-slate-800 text-lg font-semibold" id="modalVanTitle">Vehicle</p>
                    <p class="text-yellow-800 text-sm mt-1" id="modalVanType">Type</p>
                </div>
                <button onclick="closeModal()" class="text-slate-900 hover:text-slate-700 text-3xl">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <form id="checkOutForm" class="p-8 space-y-6">
                <div>
                    <label class="block text-gray-700 font-bold text-lg mb-2">Driver Name</label>
                    <input type="text" id="modalDriver" required class="w-full border-2 border-gray-300 rounded-xl px-4 py-4 text-xl focus:border-yellow-500 outline-none" placeholder="Enter full name">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-bold text-lg mb-2">Purpose</label>
                        <select id="modalPurpose" class="w-full border-2 border-gray-300 rounded-xl px-4 py-4 text-xl focus:border-yellow-500 outline-none bg-white">
                            <option value="Delivery">Delivery</option>
                            <option value="Catering">Catering</option>
                            <option value="Concessions">Concessions</option>
                            <option value="Supply Run">Supply Run</option>
                            <option value="Maintenance">Maintenance</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 font-bold text-lg mb-2">Destination</label>
                        <input type="text" id="modalDestination" class="w-full border-2 border-gray-300 rounded-xl px-4 py-4 text-xl focus:border-yellow-500 outline-none" placeholder="Location">
                    </div>
                </div>

                <div class="bg-gray-50 rounded-2xl p-6 border-2 border-gray-200">
                    <div class="flex justify-between items-center mb-4">
                        <label class="block text-gray-700 font-bold text-lg">Current Fuel Level</label>
                        <span id="modalFuelPercent" class="text-3xl font-black text-yellow-600">100%</span>
                    </div>
                    <input type="range" id="modalFuelSlider" min="0" max="100" value="100" class="fuel-slider mb-4" oninput="updateModalFuel(this.value)">
                    <div class="flex justify-between text-sm font-bold text-gray-500 uppercase">
                        <span class="text-red-600">Empty</span>
                        <span class="text-green-800">Full</span>
                    </div>
                </div>

                <button type="submit" class="w-full bg-yellow-500 hover:bg-yellow-400 text-slate-900 font-bold py-5 rounded-xl text-2xl shadow-lg transition flex items-center justify-center space-x-3">
                    <i class="fas fa-key"></i>
                    <span>Confirm Check Out</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Check-In Modal -->
    <div id="checkInModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white rounded-3xl shadow-2xl max-w-lg w-full slide-up">
            <div class="bg-blue-600 text-white px-8 py-6 flex justify-between items-center">
                <div>
                    <h3 class="text-3xl font-bold">Return Vehicle</h3>
                    <p class="text-blue-100 text-lg" id="checkInVanTitle">Vehicle</p>
                </div>
                <button onclick="closeCheckInModal()" class="text-white hover:text-blue-200 text-3xl">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <form id="checkInForm" class="p-8 space-y-6">
                <div class="bg-blue-50 rounded-2xl p-6 border-2 border-blue-200">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <div class="text-blue-900 font-bold text-lg">Driver</div>
                            <div class="text-blue-800 text-2xl font-bold" id="checkInDriver">Driver</div>
                        </div>
                        <div class="text-right">
